{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Glyph Grid Studio",
  "version": "0.1.0",
  "identifier": "art.lovespark.glyph-grid-studio",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Glyph Grid Studio",
        "width": 1500,
        "height": 820,
        "minWidth": 1100,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "dragDropEnabled": true,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "app",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "GraphicsAndDesign",
    "shortDescription": "Interactive ASCII / glyph-grid art studio",
    "longDescription": "Tunable ASCII / character-grid art renderer. Drag-drop any image, dial in palettes / breathing / dithering / postprocess via sliders, save presets, export PNG and animated GIF."
  }
}
